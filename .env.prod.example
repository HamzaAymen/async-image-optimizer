# Production env for the Hetzner box. Copy to `.env.prod` (gitignored) and fill in.
# Shared by both the api and worker containers (worker ignores the api-only vars).

# --- CHANGED from the Fly/Upstash setup ---
# Was: rediss://<user>:<pass>@<name>.upstash.io:6379  (Upstash, TLS)
# Now: the self-hosted Redis container on the internal Docker network.
REDIS_URL=redis://redis:6379

# Frontend origin allowed by CORS. PLACEHOLDER — set to the real web app
# origin once it's deployed (e.g. https://app.example.com). The api will not
# start if this is empty.
WEB_ORIGIN=https://hamza-async-image-optimizer.vercel.app

# --- UNCHANGED from Fly (Neon + R2 don't depend on where the app runs) ---
DATABASE_URL=postgresql://<neon-connection-string>
R2_ACCOUNT_ID=<r2-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET=async-image-optimizer

# Note: PORT is set to 8080 by docker-compose.prod.yml (Caddy proxies to it),
# so it does not need to be listed here.
