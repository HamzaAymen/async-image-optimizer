# Caddy reverse proxy for the API.
#
# Serves the API over HTTPS at 178-104-112-72.sslip.io. sslip.io is wildcard DNS:
# the hostname resolves to 178.104.112.72 automatically, no DNS records needed.
# Caddy obtains a real (trusted) Let's Encrypt certificate for the hostname via
# the ACME HTTP-01 challenge, so browsers accept background fetches to it.
# Port 80 must stay reachable for the challenge (ufw allows it).

{
	# email you@example.com   # uncomment to receive ACME expiry notices
	auto_https disable_redirects
}

178-104-112-72.sslip.io {
	# SSE endpoint: /jobs/:id/stream — stream events to the browser with NO
	# proxy buffering. flush_interval -1 forces Caddy to flush every write
	# straight through, so status updates arrive in real time.
	@sse path_regexp sse ^/jobs/[^/]+/stream$
	reverse_proxy @sse api:8080 {
		flush_interval -1
	}

	# Everything else. (No `encode`/gzip on purpose — compression can buffer
	# the SSE stream.)
	reverse_proxy api:8080
}

# Redirect plain HTTP to HTTPS.
178.104.112.72:80 {
	redir https://{host}{uri} permanent
}
